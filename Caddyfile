# Railway 注入 $PORT；本地測試 fallback 到 80
:{$PORT:80} {
    root * /srv
    file_server
    encode gzip zstd

    # 預設靜態資源 cache 短期（10 分鐘），方便派派改檔 cache-bust ?v=N 強刷
    header Cache-Control "public, max-age=600"

    # Godot Web build 需要 SharedArrayBuffer → 必須回 cross-origin isolation headers
    @godot {
        path /godot-beatemup/* /godot-demo2/*
    }
    header @godot {
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Embedder-Policy "require-corp"
        Cross-Origin-Resource-Policy "same-origin"
    }

    # wasm / pck demo 階段頻繁迭代，no-cache 強制每次重新拉
    @big {
        path *.wasm *.pck
    }
    header @big >Cache-Control "no-cache, no-store, must-revalidate"

    # HTML entry pages（含內嵌 JS）每次重整都拿新版，避免黏舊 logic
    # JSON 配置（編輯器存的） 也要 no-cache，否則編輯器拿舊 frame size
    @htmlAndJson {
        path *.html *.json
    }
    header @htmlAndJson >Cache-Control "no-cache, must-revalidate"

    # 不公開原始檔
    @hidden {
        path /.git/* /Dockerfile /Caddyfile /.dockerignore /godot_beatemup/* /godot_demo2/*
    }
    respond @hidden 404
}
