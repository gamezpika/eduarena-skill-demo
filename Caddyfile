# Railway 注入 $PORT；本地測試 fallback 到 80
:{$PORT:80} {
    root * /srv
    file_server
    encode gzip zstd

    # 預設靜態資源 cache 短期（10 分鐘），方便派派改檔 cache-bust ?v=N 強刷
    header Cache-Control "public, max-age=600"

    # Godot Web build 需要 SharedArrayBuffer → 必須回 cross-origin isolation headers
    @godot {
        path /godot-beatemup/*
    }
    header @godot {
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Embedder-Policy "require-corp"
        Cross-Origin-Resource-Policy "same-origin"
    }

    # wasm / pck demo 階段頻繁迭代，cache 短到 60s（用 > 強制替換預設 max-age=600）
    @big {
        path *.wasm *.pck
    }
    header @big >Cache-Control "public, max-age=60"

    # 不公開原始檔
    @hidden {
        path /.git/* /Dockerfile /Caddyfile /.dockerignore /godot_beatemup/*
    }
    respond @hidden 404
}
