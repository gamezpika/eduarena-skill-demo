; Engine configuration file.
; Godot 4.6 — top-down explore demo (像影片 3 像素 MMORPG 風)

config_version=5

[application]

config/name="TopDown Explore Demo"
config/description="Top-down 2.5D 探索 demo（Phase 1 — TileMap 草地 + WASD 走動）"
run/main_scene="res://scenes/world.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[display]

